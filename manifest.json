{
  "manifest_version": 3,
  "name": "Uboor WA Collector Pro",
  "version": "1.0",
  "description": "The ultimate tool by Uboor to extract and manage WhatsApp contacts seamlessly.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Uboor Tool"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}